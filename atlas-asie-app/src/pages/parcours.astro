---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Base title="Le parcours — Atlas d'Asie" description="Étape par étape : villes, hôtels, dates, météo. Le suivi du voyage de la famille Lahutte.">
  <Header variant="solid" active="parcours" />

  <main id="main">
    <section class="intro"><div class="wrap">
      <p class="eyebrow">Le suivi</p>
      <h1 class="disp">Le parcours</h1>
      <p class="lead">Escale après escale — où on dort, quand, et le temps qu'il fait. C'est la page à ouvrir pour savoir où on en est.</p>
      <div class="legend">
        <span><i class="dot passe"></i> Passé</span>
        <span><i class="dot en-cours"></i> En ce moment</span>
        <span><i class="dot a-venir"></i> À venir</span>
      </div>
    </div></section>

    <section class="tl"><div class="wrap">
      <div class="timeline" id="timeline">
        <div class="sk sk-card"></div><div class="sk sk-card"></div><div class="sk sk-card"></div>
      </div>
    </div></section>
  </main>

  <Footer />
</Base>

<style is:global>
  .intro{padding:clamp(30px,6vw,64px) 0 clamp(10px,3vw,24px);}
  .eyebrow{display:flex;align-items:center;gap:.6rem;font-weight:800;font-size:.76rem;letter-spacing:.16em;text-transform:uppercase;color:var(--orange-deep);margin:0 0 .4rem;}
  .eyebrow::before{content:"";width:26px;height:3px;background:var(--orange);}
  .intro h1{font-size:clamp(2.6rem,8vw,5rem);margin:0 0 .6rem;}
  .lead{color:var(--ink-soft);max-width:60ch;margin:0 0 1.2rem;font-size:1.05rem;}
  .legend{display:flex;gap:1.4rem;flex-wrap:wrap;font-size:.82rem;color:var(--ink-soft);}
  .legend i.dot{display:inline-block;width:11px;height:11px;border-radius:50%;border:2px solid var(--ink);vertical-align:-1px;margin-right:.2rem;}
  .dot.passe{background:var(--orange);} .dot.en-cours{background:var(--yellow);} .dot.a-venir{background:#fff;}

  .tl{padding:clamp(20px,3vw,32px) 0 clamp(40px,6vw,80px);}
  .timeline{position:relative;}
  .timeline::before{content:"";position:absolute;left:26px;top:8px;bottom:8px;width:3px;background:repeating-linear-gradient(var(--line) 0 10px, transparent 10px 18px);}
  .loading{color:var(--muted);padding-left:60px;}
  .avoir{margin-top:14px;}
  .avoir h3{font-family:var(--disp);text-transform:uppercase;font-size:1rem;margin:0 0 .6rem;color:var(--orange-deep);}

  /* La grande histoire — récits du pays, en tête de section */
  .grande-histoire{margin:0 0 clamp(16px,3vw,26px);padding-left:56px;}
  .grande-histoire > h3{font-family:var(--disp);text-transform:uppercase;font-size:1.15rem;margin:0 0 .8rem;color:var(--orange-deep);display:flex;align-items:center;gap:.5rem;}
  .grande-histoire > h3::before{content:"";width:22px;height:3px;background:var(--yellow);}
  .recit{border:2px solid var(--ink);border-radius:14px;background:var(--card);margin:0 0 10px;overflow:hidden;box-shadow:4px 4px 0 var(--ink);}
  .recit summary{cursor:pointer;list-style:none;padding:14px 16px;display:grid;gap:2px;}
  .recit summary::-webkit-details-marker{display:none;}
  .recit .rtit{font-family:var(--disp);text-transform:uppercase;font-size:1.05rem;color:var(--ink);}
  .recit .racc{color:var(--ink-soft);font-size:.92rem;}
  .recit .rplus{margin-top:4px;font-size:.72rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;color:var(--orange-deep);}
  .recit .rplus::after{content:" ▾";}
  .recit[open] .rplus::after{content:" ▴";}
  .recit .rbody{padding:4px 18px 20px;}
  .recit .rbody p{font-family:'Fraunces',Georgia,serif;font-size:1.06rem;line-height:1.75;max-width:64ch;color:var(--ink);margin:0 0 1em;}
  .recit .rimg{width:100%;max-height:260px;object-fit:cover;border-radius:10px;border:1px solid var(--line);margin:0 0 14px;}
  .lieux{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:10px;}
  .lieu{border:1px solid var(--line);border-radius:12px;background:var(--card);overflow:hidden;}
  .lieu .limg{width:100%;aspect-ratio:16/9;object-fit:cover;}
  .lieu .ltxt{padding:9px 11px 11px;}
  .lieu .ln{font-weight:700;font-size:.92rem;}
  .lieu .unesco{display:inline-block;margin-left:.4rem;vertical-align:1px;font-size:.6rem;font-weight:800;letter-spacing:.08em;text-transform:uppercase;background:var(--teal);color:#fff;border-radius:999px;padding:2px 8px;}
  .lieu .ld{margin:.3rem 0 0;font-size:.82rem;color:var(--ink-soft);}
  .leg{position:relative;display:grid;grid-template-columns:56px 1fr;gap:clamp(14px,2.5vw,28px);padding:clamp(12px,2vw,20px) 0;scroll-margin-top:90px;}
  .rail{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;gap:6px;}
  .rail .node{width:20px;height:20px;border-radius:50%;border:3px solid var(--ink);background:#fff;margin-top:6px;}
  .leg--passe .rail .node{background:var(--orange);}
  .leg--en-cours .rail .node{background:var(--yellow);box-shadow:0 0 0 0 rgba(243,234,93,.7);animation:pinpulse 1.8s infinite;}
  .rail .ord{font-family:var(--disp);font-size:1.1rem;color:var(--muted);}
  .card{background:var(--card);border:2px solid var(--ink);border-radius:var(--r);box-shadow:var(--shadow);overflow:hidden;transition:transform .18s ease, box-shadow .18s ease;}
  .card:hover{transform:translate(-2px,-2px);box-shadow:8px 8px 0 var(--orange);}
  .card .body{padding:clamp(16px,2.4vw,24px);}
  .chead{display:flex;align-items:center;justify-content:space-between;gap:1rem;flex-wrap:wrap;}
  .statut{font-size:.64rem;font-weight:800;letter-spacing:.12em;text-transform:uppercase;padding:3px 10px;border-radius:999px;color:#fff;}
  .statut.passe{background:var(--orange);} .statut.en-cours{background:var(--teal);} .statut.a-venir{background:var(--muted);}
  .wx{display:inline-flex;align-items:center;gap:.4rem;font-size:.85rem;color:var(--ink-soft);font-variant-numeric:tabular-nums;}
  .wx svg{color:var(--orange-deep);}
  .card h2{font-family:var(--disp);font-size:clamp(1.4rem,3vw,2rem);text-transform:uppercase;margin:.5rem 0 .2rem;}
  .cmeta{color:var(--muted);font-size:.86rem;font-variant-numeric:tabular-nums;margin-bottom:.7rem;}
  .desc{color:var(--ink-soft);margin:0 0 1rem;max-width:66ch;}
  .hotel{display:flex;gap:14px;align-items:flex-start;background:var(--peach);border:1px solid var(--line);border-radius:12px;padding:12px 14px;}
  .hotel .hicon{color:var(--orange-deep);flex:none;margin-top:2px;}
  .hotel .hnom{font-weight:700;}
  .hotel .hadr{font-size:.84rem;color:var(--ink-soft);}
  .hotel a.hlink{font-size:.8rem;font-weight:700;color:var(--orange-deep);text-decoration:none;border-bottom:2px solid var(--yellow);}
  .hotel img{width:110px;height:80px;object-fit:cover;border-radius:8px;border:1px solid var(--line);}
  .media{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px;}
  .media img{width:120px;height:84px;object-fit:cover;border-radius:8px;border:1px solid var(--line);}
  .media a.vid{align-self:center;font-size:.82rem;font-weight:700;color:var(--orange-deep);}

  @media (max-width:560px){.leg{grid-template-columns:40px 1fr;gap:12px;}.timeline::before{left:18px;}.hotel img{display:none;}.grande-histoire{padding-left:40px;}}
</style>

<script>
  import { fetchTab } from '../lib/data';
  import { toStops, toLieux, toRecits } from '../lib/model';
  import type { Stop, Lieu, Recit } from '../lib/model';
  import { paysHead } from '../lib/paysMeta';
  import { loadPhotos, ccImg } from '../lib/photos';
  import { fetchWeather, weatherIcon } from '../lib/weather';

  const MON = ['janv.', 'févr.', 'mars', 'avr.', 'mai', 'juin', 'juil.', 'août', 'sept.', 'oct.', 'nov.', 'déc.'];
  const dm = (d: Date | null) => (d ? `${d.getDate()} ${MON[d.getMonth()]}` : '');
  const STAT: Record<Stop['statut'], string> = { passe: 'Passé', 'en-cours': 'En ce moment', 'a-venir': 'À venir' };
  const esc = (s: string) => s.replace(/[&<>"]/g, (c) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;' }[c] as string));

  const HOTEL_ICON = '<svg class="hicon" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 21h18M5 21V5a1 1 0 0 1 1-1h8a1 1 0 0 1 1 1v16M15 21V9h3a1 1 0 0 1 1 1v11M8 7h.01M11 7h.01M8 11h.01M11 11h.01M8 15h.01M11 15h.01"/></svg>';

  function datesLabel(s: Stop): string {
    if (s.arrivee && s.depart) return `${dm(s.arrivee)} → ${dm(s.depart)} ${s.depart.getFullYear()}`;
    if (s.arrivee) return `à partir du ${dm(s.arrivee)} ${s.arrivee.getFullYear()}`;
    return '';
  }

  function hotelBlock(s: Stop): string {
    if (!s.hotelNom) return '';
    const nom = s.hotelLien
      ? `<a class="hlink" href="${esc(s.hotelLien)}" target="_blank" rel="noopener">${esc(s.hotelNom)} →</a>`
      : `<span class="hnom">${esc(s.hotelNom)}</span>`;
    const adr = s.hotelAdresse ? `<div class="hadr">${esc(s.hotelAdresse)}</div>` : '';
    const img = s.hotelPhoto ? `<img src="${esc(s.hotelPhoto)}" alt="Hôtel ${esc(s.hotelNom)}" loading="lazy" />` : '';
    return `<div class="hotel">${HOTEL_ICON}<div><div>${nom}</div>${adr}</div>${img}</div>`;
  }

  // « À voir » : les incontournables de l'escale (onglet Lieux, badge UNESCO).
  function lieuxBlock(items: Lieu[]): string {
    if (!items.length) return '';
    const body = items
      .map((l) => {
        const img = ccImg(l.photoQuery, l.lieu, 'limg');
        const badge = l.statut ? `<span class="unesco">${esc(l.statut)}</span>` : '';
        return `<div class="lieu">${img}<div class="ltxt"><div class="ln">${esc(l.lieu)}${badge}</div><p class="ld">${esc(l.texte)}</p></div></div>`;
      })
      .join('');
    return `<div class="avoir"><h3>À voir</h3><div class="lieux">${body}</div></div>`;
  }

  // « La grande histoire » : les récits longs du pays, en tête de sa section.
  function recitsBlock(recits: Recit[]): string {
    if (!recits.length) return '';
    const body = recits
      .map((r) => {
        const img = ccImg(r.photoQuery, r.titre, 'rimg');
        const paras = r.texte.split(/\n{2,}/).map((t) => `<p>${esc(t.trim())}</p>`).join('');
        return `<details class="recit"><summary><span class="rtit">${esc(r.titre)}</span><span class="racc">${esc(r.accroche)}</span><span class="rplus">Lire la suite</span></summary><div class="rbody">${img}${paras}</div></details>`;
      })
      .join('');
    return `<div class="grande-histoire"><h3>La grande histoire</h3>${body}</div>`;
  }

  function mediaBlock(s: Stop): string {
    const imgs = s.photos.map((u) => `<img src="${esc(u)}" alt="Photo ${esc(s.ville)}" loading="lazy" />`).join('');
    const vid = s.video ? `<a class="vid" href="${esc(s.video)}" target="_blank" rel="noopener">▶ Vidéo</a>` : '';
    return imgs || vid ? `<div class="media">${imgs}${vid}</div>` : '';
  }

  (async () => {
    const host = document.getElementById('timeline')!;
    try {
      const [pRows, lieuxRows, recitsRows] = await Promise.all([
        fetchTab('parcours'),
        fetchTab('lieux').catch(() => []),
        fetchTab('recits').catch(() => []),
        loadPhotos(),
      ]);
      const stops = toStops(pRows);
      const lieux = toLieux(lieuxRows);
      const recits = toRecits(recitsRows);
      let paysCourant = '';
      host.innerHTML = stops
        .map((s) => {
          let head = '';
          if (s.pays !== paysCourant) {
            paysCourant = s.pays;
            head = paysHead(s.pays) + recitsBlock(recits.filter((r) => r.pays.includes(s.pays)));
          }
          return `${head}
        <article class="leg leg--${s.statut}" id="e-${s.ordre}">
          <div class="rail"><span class="node"></span><span class="ord">${s.ordre}</span></div>
          <div class="card"><div class="body">
            <div class="chead">
              <span class="statut ${s.statut}">${STAT[s.statut]}</span>
              ${s.lat && s.lng ? `<span class="wx" data-lat="${s.lat}" data-lng="${s.lng}">…</span>` : ''}
            </div>
            <h2>${esc(s.ville)}</h2>
            <div class="cmeta">${esc(s.pays)}${datesLabel(s) ? ' · ' + datesLabel(s) : ''}</div>
            ${s.description ? `<p class="desc">${esc(s.description)}</p>` : ''}
            ${hotelBlock(s)}
            ${lieuxBlock(lieux.filter((l) => l.ordre === s.ordre))}
            ${mediaBlock(s)}
          </div></div>
        </article>`;
        })
        .join('');

      // Météo paresseuse : on ne sollicite Open-Meteo qu'à l'apparition de la carte.
      const wio = new IntersectionObserver((es) => {
        es.forEach(async (e) => {
          if (!e.isIntersecting) return;
          const el = e.target as HTMLElement;
          wio.unobserve(el);
          const w = await fetchWeather(+el.dataset.lat!, +el.dataset.lng!);
          el.innerHTML = w ? `${weatherIcon(w.cat)} ${w.temp}° · ${w.label}` : '';
        });
      }, { rootMargin: '100px' });
      document.querySelectorAll('.wx').forEach((el) => wio.observe(el));

      // Si on arrive avec un hash (#e-N) depuis la carte, on y va en douceur.
      if (location.hash) {
        const t = document.getElementById(location.hash.slice(1));
        if (t) setTimeout(() => t.scrollIntoView({ behavior: 'smooth', block: 'center' }), 100);
      }
    } catch (err) {
      host.innerHTML = `<p class="loading">${String(err)}</p>`;
    }
  })();
</script>
