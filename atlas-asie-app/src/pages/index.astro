---
import Base from '../layouts/Base.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
// Pool de heros iconiques du voyage — un tirage aléatoire à chaque chargement.
// Le premier sert de rendu par défaut (crawlers / sans JS) ; le crédit du
// footer suit la photo tirée.
const HEROES = [
  { img: 'brand/hero-issyk-kul.jpg', lieu: 'Lac Issyk-Kul · Kirghizistan', credit: "Coucher de soleil sur le lac Issyk-Kul, Kirghizistan — Wikimedia Commons, CC BY-SA 2.0" },
  { img: 'brand/hero-zhangjiajie.jpg', lieu: 'Zhangjiajie · Chine', credit: "Forêt de pics de Tianzi Shan, Zhangjiajie, Chine — chensiyuan, Wikimedia Commons, CC BY-SA 4.0" },
  { img: 'brand/hero-padar.jpg', lieu: 'Île de Padar, Komodo · Indonésie', credit: "L'île de Padar, parc national de Komodo, Indonésie — Jakub Hałun, Wikimedia Commons, CC BY 4.0" },
];
const heroCredit = HEROES[0].credit;
---
<Base>
  <Header variant="over" active="accueil" />

  <!-- HERO -->
  <section class="hero">
    <div class="hero-bg" id="hero-bg" style={`background-image:url('${HEROES[0].img.startsWith('http') ? HEROES[0].img : base + HEROES[0].img}')`}></div>
    <script is:inline define:vars={{ HEROES, base }}>
      // Exécuté avant la première peinture : seule la photo tirée est téléchargée.
      (function () {
        const h = HEROES[Math.floor(Math.random() * HEROES.length)];
        document.getElementById('hero-bg').style.backgroundImage = `url('${base}${h.img}')`;
        addEventListener('DOMContentLoaded', () => {
          const l = document.getElementById('hero-lieu');
          if (l) l.textContent = h.lieu;
          const c = document.getElementById('hero-credit');
          if (c) c.textContent = h.credit + ' · ';
        });
      })();
    </script>
    <div class="scrim"></div>
    <div class="hero-mark">
      <img src={`${base}brand/amhe-icon-white.png`} alt="" aria-hidden="true" width="1200" height="850" />
      <span class="lieu" id="hero-lieu">{HEROES[0].lieu}</span>
    </div>
    <div class="inner"><div class="wrap">
      <span class="badge">Carnet de voyage · Été 2026</span>
      <h1 class="disp title">AMHE</h1>
      <p class="under"><span class="ad">Atlas d'Asie</span><span class="one">— One Love</span></p>
      <p class="sub">Le voyage de la famille Lahutte — du Kazakhstan à l'Indonésie. Où on est, où on va, et tout ce qu'il y a à découvrir.</p>
      <div class="live"><span class="pulse"></span><span id="live-txt">Chargement…</span><span class="cd" id="live-cd"></span></div>
    </div></div>
  </section>

  <!-- CARTE (remonte sur le hero) -->
  <div class="routewrap"><div class="wrap">
    <div class="routecard">
      <div class="rhead"><span class="t">L'itinéraire</span><span class="k" id="route-k">Kazakhstan → Indonésie</span></div>
      <div id="map" role="application" aria-label="Carte interactive de l'itinéraire"></div>
      <p class="rhint">Clique un point pour l'étape et le pays · molette pour zoomer une fois la carte sélectionnée</p>
    </div>
  </div></div>

  <!-- COMPTEURS -->
  <section class="counters" aria-label="Le voyage en chiffres"><div class="wrap">
    <div class="counter"><b id="c-pays" data-count="0">0</b><span>Pays</span></div>
    <div class="counter"><b id="c-escales" data-count="0">0</b><span>Escales</span></div>
    <div class="counter"><b id="c-nuits" data-count="0">0</b><span>Nuits</span></div>
    <div class="counter"><b id="c-km" data-count="0">0</b><span>km parcourus</span></div>
    <div class="counter"><b id="c-jours" data-count="0">0</b><span>Jours</span></div>
  </div></section>

  <!-- PAYS (tampons) -->
  <main id="main">
    <section class="section" id="pays"><div class="wrap">
      <p class="eyebrow">Découverte</p>
      <h2 class="disp">Les <span class="hl">pays</span> du voyage</h2>
      <div class="stamps" id="stamps"></div>
    </div></section>
  </main>

  <Footer credit={heroCredit} />
</Base>

<style is:global>
  .hero{position:relative;min-height:100svh;display:flex;align-items:flex-end;color:#fff;overflow:hidden;background:#0c0a08;}
  .hero-bg{position:absolute;inset:-3%;background-size:cover;background-position:center;transform:scale(1.06);animation:kenburns 26s ease-in-out infinite alternate;z-index:0;}
  .scrim{position:absolute;inset:0;z-index:1;background:linear-gradient(180deg,rgba(20,12,8,.32) 0%,rgba(20,12,8,0) 26%,rgba(20,12,8,.10) 55%,rgba(20,12,8,.80) 100%);}
  @keyframes kenburns{0%{transform:scale(1.06) translate3d(0,0,0)}100%{transform:scale(1.15) translate3d(0,-1.4%,0)}}
  .hero .inner{position:relative;z-index:2;width:100%;padding-bottom:clamp(96px,12vw,150px);}
  .badge{display:inline-flex;align-items:center;gap:.5rem;background:var(--orange);color:#fff;font-weight:800;font-size:.74rem;letter-spacing:.16em;text-transform:uppercase;padding:7px 15px;border-radius:999px;}
  .title{font-size:clamp(4.5rem,20vw,13rem);margin:1rem 0 .1rem;text-shadow:0 6px 34px rgba(0,0,0,.4);letter-spacing:.01em;}
  .under{display:flex;align-items:baseline;gap:.7rem;flex-wrap:wrap;margin:0 0 1.2rem;}
  .under .ad{font-family:var(--disp);text-transform:uppercase;font-size:clamp(1.4rem,4vw,2.4rem);letter-spacing:.02em;}
  .under .one{color:var(--yellow);font-weight:800;letter-spacing:.28em;font-size:.8rem;text-transform:uppercase;}
  .sub{max-width:44ch;font-size:clamp(1.05rem,2vw,1.3rem);opacity:.97;margin:0 0 1.5rem;}
  .live{display:inline-flex;align-items:center;gap:1rem;flex-wrap:wrap;background:rgba(20,12,8,.5);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.28);border-radius:14px;padding:12px 18px;}
  .live .pulse{width:11px;height:11px;border-radius:50%;background:var(--yellow);box-shadow:0 0 0 0 rgba(243,234,93,.7);animation:pulse 2s infinite;}
  @keyframes pulse{0%{box-shadow:0 0 0 0 rgba(243,234,93,.7)}70%{box-shadow:0 0 0 12px rgba(243,234,93,0)}100%{box-shadow:0 0 0 0 rgba(243,234,93,0)}}
  .live .cd{font-family:var(--disp);font-size:1.6rem;color:var(--yellow);font-variant-numeric:tabular-nums;}

  .routewrap{position:relative;z-index:6;margin-top:clamp(-130px,-9vw,-80px);}
  .routecard{background:var(--teal);border:3px solid var(--ink);border-radius:var(--r);overflow:hidden;box-shadow:8px 8px 0 var(--ink);}
  .rhead{display:flex;align-items:center;justify-content:space-between;gap:1rem;padding:12px 18px;background:var(--ink);color:var(--cream);flex-wrap:wrap;}
  .rhead .t{font-family:var(--disp);font-size:1.1rem;letter-spacing:.04em;text-transform:uppercase;}
  .rhead .k{font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;color:var(--yellow);font-weight:700;}
  #map{height:clamp(340px,54vh,560px);background:#0b1020;}
  .rhint{margin:0;padding:8px 14px;background:var(--ink);color:#9a8c73;font-size:.72rem;letter-spacing:.02em;text-align:center;}

  .counters{background:var(--ink);color:var(--cream);}
  .counters .wrap{display:grid;grid-template-columns:repeat(5,1fr);gap:1rem;padding:clamp(26px,4vw,44px) clamp(20px,5vw,56px);}
  .counter b{font-family:var(--disp);font-size:clamp(2rem,5vw,3.4rem);display:block;line-height:1;color:var(--yellow);font-variant-numeric:tabular-nums;}
  .counter span{font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:#d9c9ad;}

  .section{padding:clamp(44px,6vw,84px) 0;}
  .eyebrow{display:flex;align-items:center;gap:.6rem;font-weight:800;font-size:.76rem;letter-spacing:.16em;text-transform:uppercase;color:var(--orange-deep);margin:0 0 .6rem;}
  .eyebrow::before{content:"";width:26px;height:3px;background:var(--orange);}
  .section h2{font-size:clamp(2rem,5.5vw,3.4rem);margin:0 0 1.6rem;}
  .section h2 .hl{background:linear-gradient(transparent 62%, var(--yellow) 62%);padding:0 .1em;}
  .stamps{display:grid;grid-template-columns:repeat(auto-fit,minmax(150px,1fr));gap:clamp(14px,2vw,26px);}
  .stamp{display:flex;flex-direction:column;align-items:center;text-align:center;gap:.5rem;opacity:0;transform:translateY(16px) scale(.62) rotate(-12deg);}
  .stamp.in{opacity:1;transform:none;transition:opacity .5s ease, transform .55s cubic-bezier(.2,.9,.3,1.35);}
  .stamp .medallion{transition:transform .25s ease;}
  .stamp:hover .medallion{transform:rotate(-5deg) scale(1.05);}
  .stamp h3{font-weight:700;font-size:1rem;margin:.1rem 0 0;}
  .stamp small{color:var(--muted);font-size:.8rem;}

  .hero-mark{position:absolute;z-index:1;right:clamp(24px,7vw,110px);top:44%;transform:translateY(-50%);width:clamp(150px,20vw,300px);display:flex;flex-direction:column;align-items:center;gap:12px;}
  .hero-mark img{width:100%;height:auto;opacity:.92;filter:drop-shadow(0 10px 40px rgba(0,0,0,.45));}
  .hero-mark .lieu{display:inline-flex;align-items:center;gap:.45rem;background:rgba(20,12,8,.5);backdrop-filter:blur(8px);border:1px solid rgba(255,255,255,.28);border-radius:999px;padding:6px 13px;font-size:.72rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;white-space:nowrap;color:#fff;}
  .hero-mark .lieu::before{content:"";width:9px;height:9px;border-radius:50%;background:var(--yellow);flex:none;}
  @media (max-width:820px){.hero-mark{width:112px;top:96px;right:16px;transform:none;align-items:flex-end;gap:9px;}.hero-mark .lieu{font-size:.62rem;padding:5px 10px;}}

  @media (prefers-reduced-motion:reduce){.hero-bg{transform:none!important;}.stamp{opacity:1;transform:none;}}
  @media (max-width:820px){.counters .wrap{grid-template-columns:repeat(3,1fr);}}
  @media (max-width:480px){.counters .wrap{grid-template-columns:repeat(2,1fr);}}
</style>

<script>
  import { fetchTab } from '../lib/data';
  import { toStops, toCountries, computeCounters, computeLive } from '../lib/model';
  import type { Stop, Country } from '../lib/model';
  import { initMap } from '../lib/map';

  const BASE = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';

  // Présentation par pays (code + palette + capitale courte pour le tampon).
  const META: Record<string, { code: string; cap: string; pal: [string, string, string] }> = {
    Kazakhstan: { code: 'KZ', cap: 'Astana', pal: ['#FFB22E', '#FA4616', '#C9330B'] },
    Kirghizistan: { code: 'KG', cap: 'Bichkek', pal: ['#36C9A3', '#149E7C', '#0C5A5E'] },
    Mongolie: { code: 'MN', cap: 'Oulan-Bator', pal: ['#FFCF6B', '#E89B2E', '#B86A12'] },
    Chine: { code: 'CN', cap: 'Pékin', pal: ['#FF8DA3', '#F2516F', '#C12B49'] },
    'Hong-Kong': { code: 'HK', cap: 'Hong Kong', pal: ['#5BC8E8', '#1E96C8', '#0C5A7E'] },
    Indonésie: { code: 'ID', cap: 'Jakarta', pal: ['#36C9A3', '#149E7C', '#0C5A5E'] },
    Malaisie: { code: 'MY', cap: 'Kuala Lumpur', pal: ['#F3EA5D', '#E89B2E', '#B86A12'] },
  };
  const codeFor = (nom: string) => META[nom]?.code ?? nom.slice(0, 2).toUpperCase();
  const capFor = (c: Country) => META[c.pays]?.cap ?? c.capitale.split(/[(,]/)[0].trim();
  const palFor = (nom: string): [string, string, string] => META[nom]?.pal ?? ['#FFB22E', '#FA4616', '#C9330B'];

  const $ = (id: string) => document.getElementById(id)!;

  function countUp(el: HTMLElement) {
    if (el.dataset.done) return;
    el.dataset.done = '1';
    const target = +(el.dataset.count || '0');
    const t0 = performance.now();
    const step = (t: number) => {
      const p = Math.min(1, (t - t0) / 1100);
      el.textContent = Math.round(target * (1 - Math.pow(1 - p, 3))).toLocaleString('fr-FR');
      if (p < 1) requestAnimationFrame(step);
    };
    requestAnimationFrame(step);
  }

  function renderCounters(c: { pays: number; escales: number; nuits: number; km: number; jours: number }) {
    ($('c-pays') as HTMLElement).dataset.count = String(c.pays);
    ($('c-escales') as HTMLElement).dataset.count = String(c.escales);
    ($('c-nuits') as HTMLElement).dataset.count = String(c.nuits);
    ($('c-km') as HTMLElement).dataset.count = String(c.km);
    ($('c-jours') as HTMLElement).dataset.count = String(c.jours);
    const io = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { countUp(e.target as HTMLElement); io.unobserve(e.target); } }), { threshold: 0.4 });
    document.querySelectorAll('[data-count]').forEach((el) => io.observe(el));
    setTimeout(() => document.querySelectorAll('[data-count]').forEach((el) => countUp(el as HTMLElement)), 2000);
  }

  function renderLive(live: ReturnType<typeof computeLive>) {
    const txt = $('live-txt'), cd = $('live-cd');
    if (live.state === 'avant') {
      txt.innerHTML = `Départ pour <strong>${live.next?.ville ?? ''}</strong> dans`;
      cd.textContent = live.daysToStart + ' j';
    } else if (live.state === 'pendant' && live.current) {
      txt.innerHTML = `Jour ${live.dayIndex} · on est à <strong>${live.current.ville}</strong>`;
      cd.textContent = live.next ? '→ ' + live.next.ville : '';
    } else {
      txt.innerHTML = '<strong>Voyage terminé</strong> — merci de nous avoir suivis';
      cd.textContent = '';
    }
  }

  function stampSVG(c: Country) {
    const [a, b, d] = palFor(c.pays);
    const code = codeFor(c.pays), cap = capFor(c).toUpperCase(), id = 'a_' + code;
    return `<svg class="medallion" width="138" height="138" viewBox="0 0 150 150" role="img" aria-label="Tampon ${c.pays}"><circle cx="75" cy="75" r="70" fill="none" stroke="${b}" stroke-width="3"/><circle cx="75" cy="75" r="62" fill="none" stroke="${b}" stroke-width="1" stroke-dasharray="3 4"/><circle cx="75" cy="60" r="15" fill="${a}"/><path d="M28 98 56 64 80 92 100 68 122 98Z" fill="${d}"/><path d="M28 98h94" stroke="${b}" stroke-width="2"/><path id="${id}" d="M75 16a59 59 0 0 1 0 118" fill="none"/><text font-family="Inter,sans-serif" font-weight="700" font-size="11" letter-spacing="2.5" fill="${d}"><textPath href="#${id}" startOffset="4%">${cap}</textPath></text><text x="75" y="128" text-anchor="middle" font-family="Anton,sans-serif" font-size="20" fill="${d}">${code}</text></svg>`;
  }

  function renderStamps(countries: Country[]) {
    const host = $('stamps');
    host.innerHTML = countries
      .filter((c) => c.pays && c.pays.toLowerCase() !== 'france')
      .map((c) => `<div class="stamp">${stampSVG(c)}<h3>${c.pays}</h3><small>${c.capitale.split(/[(,]/)[0].trim()}</small></div>`)
      .join('');
    const reveal = () => [...document.querySelectorAll('.stamp:not(.in)')].forEach((s, i) => setTimeout(() => s.classList.add('in'), i * 80));
    const so = new IntersectionObserver((es) => es.forEach((e) => { if (e.isIntersecting) { reveal(); so.disconnect(); } }), { threshold: 0.15 });
    so.observe(host);
    setTimeout(reveal, 2000);
  }

  (async () => {
    try {
      const [pRows, cRows] = await Promise.all([fetchTab('parcours'), fetchTab('pays')]);
      const stops = toStops(pRows);
      const countries = toCountries(cRows);
      renderCounters(computeCounters(stops));
      renderLive(computeLive(stops));
      renderStamps(countries);
      initMap($('map'), stops, BASE);
      const first = stops.find((s) => s.pays.toLowerCase() !== 'france');
      const lastVisited = [...stops].reverse().find((s) => s.pays.toLowerCase() !== 'france');
      if (first && lastVisited) $('route-k').textContent = `${first.pays} → ${lastVisited.pays}`;
    } catch (err) {
      $('live-txt').textContent = String(err);
    }
  })();

  // Bascule de langue (démo — l'EN complet viendra plus tard).
  document.querySelectorAll('.lang button').forEach((b) =>
    b.addEventListener('click', () => {
      document.querySelectorAll('.lang button').forEach((x) => x.setAttribute('aria-pressed', 'false'));
      b.setAttribute('aria-pressed', 'true');
    }),
  );
</script>
