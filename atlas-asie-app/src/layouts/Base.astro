---
import '../styles/tokens.css';
interface Props {
  title?: string;
  description?: string;
  lang?: string;
}
const {
  title = "Atlas d'Asie — AMHE",
  description = "Le voyage de la famille Lahutte, du Kazakhstan à l'Indonésie. Suivi en direct, pays, étapes et découvertes.",
  lang = 'fr',
} = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
// Toutes les routes sont des dossiers : canonical normalisé avec slash final.
const canonical = new URL(
  Astro.url.pathname.endsWith('/') ? Astro.url.pathname : Astro.url.pathname + '/',
  Astro.site,
);
const siteUrl = new URL(base, Astro.site).href;
// JSON-LD authorship (GEO) : même @id #hugo canonique que le reste du domaine.
const HUGO = 'https://hl-consulting.tech/#hugo';
const ld = {
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'Person', '@id': HUGO, name: 'Hugo Lahutte', url: 'https://hl-consulting.tech/' },
    {
      '@type': 'WebSite',
      '@id': siteUrl + '#site',
      url: siteUrl,
      name: "Atlas d'Asie — AMHE",
      inLanguage: 'fr-FR',
      author: { '@id': HUGO },
      about:
        "Carnet de voyage de la famille Lahutte en Asie, été 2026 : parcours en direct du Kazakhstan à l'Indonésie, fiches pays éducatives (evergreen), photos.",
    },
    {
      '@type': 'WebPage',
      url: canonical.href,
      name: title,
      description,
      inLanguage: lang === 'en' ? 'en' : 'fr-FR',
      isPartOf: { '@id': siteUrl + '#site' },
      author: { '@id': HUGO },
    },
  ],
};
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical.href} />
    <meta name="theme-color" content="#FA4616" />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="icon" href={`${base}favicon-32.png`} sizes="32x32" type="image/png" />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical.href} />
    <meta property="og:image" content={new URL(`${base}brand/og.jpg`, Astro.site).href} />
    <meta property="og:image:alt" content="AMHE — Atlas d'Asie, le voyage de la famille Lahutte" />
    <meta property="og:locale" content="fr_FR" />
    <meta property="og:site_name" content="Atlas d'Asie — AMHE" />
    <meta name="twitter:card" content="summary_large_image" />
    <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    <link rel="manifest" href={`${base}manifest.webmanifest`} />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-title" content="Atlas d'Asie" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Anton&family=Fraunces:opsz,wght@9..144,500;9..144,600&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <a href="#main" class="skip-link">Aller au contenu</a>
    <div id="progress" aria-hidden="true"></div>
    <div id="splash" aria-hidden="true"><img src={`${base}brand/amhe-anim.gif`} alt="" width="300" height="256" /></div>
    <slot />
    <div id="offline" role="status">Hors ligne — dernières infos connues</div>

    <style is:global>
      #progress{position:fixed;top:0;left:0;height:4px;width:0;z-index:70;background:linear-gradient(90deg,var(--orange),var(--yellow));}
      #splash{position:fixed;inset:0;z-index:100;background:#fff;display:grid;place-items:center;transition:opacity .6s ease;}
      #splash img{width:min(300px,62vw);height:auto;}
      #splash.done{opacity:0;pointer-events:none;}
      @media (prefers-reduced-motion:reduce){#splash{display:none;}}
    </style>

    <script>
      // Splash d'intro (logo AMHE animé ~3.6s), clic pour passer, 1×/session.
      (function () {
        const s = document.getElementById('splash');
        if (!s) return;
        const rm = matchMedia('(prefers-reduced-motion:reduce)').matches;
        const kill = () => { s.classList.add('done'); setTimeout(() => s.remove(), 700); };
        if (rm || sessionStorage.getItem('amhe_splash')) { s.remove(); return; }
        sessionStorage.setItem('amhe_splash', '1');
        s.addEventListener('click', kill);
        setTimeout(kill, 3600);
      })();
      // Barre de progression au scroll.
      (function () {
        const p = document.getElementById('progress');
        if (!p) return;
        const h = document.documentElement;
        const upd = () => {
          const m = h.scrollHeight - h.clientHeight;
          p.style.width = (m > 0 ? (h.scrollTop / m) * 100 : 0) + '%';
        };
        addEventListener('scroll', upd, { passive: true });
        addEventListener('resize', upd);
        upd();
      })();
      // PWA : service worker + indicateur hors-ligne.
      (function () {
        const base = document.querySelector('link[rel="manifest"]')?.getAttribute('href')?.replace('manifest.webmanifest', '') || '/';
        if ('serviceWorker' in navigator) navigator.serviceWorker.register(base + 'sw.js').catch(() => {});
        const setOff = () => document.body.toggleAttribute('data-offline', !navigator.onLine);
        addEventListener('online', setOff);
        addEventListener('offline', setOff);
        setOff();
      })();
    </script>
  </body>
</html>
