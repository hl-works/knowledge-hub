---
// Header AMHE. variant="over" (transparent sur le hero) | "solid" (fond encre).
// Desktop : nav en haut. Mobile : barre d'onglets en bas (+ « Plus »).
interface Props { variant?: 'over' | 'solid'; active?: string; }
const { variant = 'solid', active = '' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
const links = [
  { href: base, label: 'Accueil', key: 'accueil' },
  { href: base + 'parcours', label: 'Parcours', key: 'parcours' },
  { href: base + 'pays', label: 'Pays', key: 'pays' },
  { href: base + 'hotels', label: 'Hôtels', key: 'hotels' },
  { href: base + 'trajets', label: 'Trajets', key: 'trajets' },
  { href: base + 'carnet', label: 'Carnet', key: 'carnet' },
  { href: base + 'galerie', label: 'Galerie', key: 'galerie' },
];
const I = {
  home: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 11l9-8 9 8M5 10v10h14V10"/></svg>',
  route: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="19" r="2"/><circle cx="18" cy="5" r="2"/><path d="M8 19h6a4 4 0 0 0 0-8H10a4 4 0 0 1 0-8h6"/></svg>',
  globe: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M3 12h18M12 3a15 15 0 0 1 0 18M12 3a15 15 0 0 0 0 18"/></svg>',
  bed: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M3 18V7M3 12h18a0 0 0 0 1 0 0v6M21 18v-3M7 12v-2a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v2"/></svg>',
  plus: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="9"/><path d="M12 8v8M8 12h8"/></svg>',
  plane: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M17.8 19.2 16 11l3.5-3.5a2 2 0 0 0-2.8-2.8L13 8.2 4.8 6.4a1 1 0 0 0-.9 1.7l6 3.3-2.3 2.3-2-.3-1 1 3 1.5L12 20l1-1-.3-2 2.3-2.3 3.3 6a1 1 0 0 0 1.7-.9Z"/></svg>',
  cam: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="15" rx="3"/><circle cx="12" cy="12" r="3.4"/><path d="M8 5l1.5-2h5L16 5"/></svg>',
  grid: '<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>',
};
const isMore = ['trajets', 'carnet', 'galerie'].includes(active);
---
<header class:list={['hdr', variant]}>
  <div class="wrap">
    <a class="brand" href={base}>
      <img class="mark" src={`${base}brand/amhe-icon-white.png`} alt="Logo AMHE" width="40" height="29" />
      <span class="wm"><span class="t">AMHE</span><span class="s">Atlas d'Asie</span></span>
    </a>
    <nav class="nav" aria-label="Principale">
      <span class="links">
        {links.map((l) => (
          <a href={l.href} aria-current={active === l.key ? 'page' : undefined}>{l.label}</a>
        ))}
      </span>
      <span class="lang" role="group" aria-label="Langue">
        <button type="button" aria-pressed="true">FR</button>
        <button type="button" aria-pressed="false">EN</button>
      </span>
    </nav>
  </div>
</header>

<!-- Barre d'onglets mobile -->
<nav class="tabbar" aria-label="Navigation">
  <a href={base} aria-current={active === 'accueil' ? 'page' : undefined}><Fragment set:html={I.home} /><span>Accueil</span></a>
  <a href={base + 'parcours'} aria-current={active === 'parcours' ? 'page' : undefined}><Fragment set:html={I.route} /><span>Parcours</span></a>
  <a href={base + 'pays'} aria-current={active === 'pays' ? 'page' : undefined}><Fragment set:html={I.globe} /><span>Pays</span></a>
  <a href={base + 'hotels'} aria-current={active === 'hotels' ? 'page' : undefined}><Fragment set:html={I.bed} /><span>Hôtels</span></a>
  <button type="button" id="more-btn" aria-expanded={isMore ? 'true' : 'false'} aria-controls="more-sheet"><Fragment set:html={I.plus} /><span>Plus</span></button>
</nav>
<div class="more-sheet" id="more-sheet" role="menu">
  <a href={base + 'trajets'} aria-current={active === 'trajets' ? 'page' : undefined}><Fragment set:html={I.plane} />Les trajets</a>
  <a href={base + 'carnet'} aria-current={active === 'carnet' ? 'page' : undefined}><Fragment set:html={I.cam} />Le carnet</a>
  <a href={base + 'galerie'} aria-current={active === 'galerie' ? 'page' : undefined}><Fragment set:html={I.grid} />Galerie</a>
</div>

<style>
  .hdr{z-index:40;}
  .hdr.over{position:absolute;top:0;left:0;right:0;color:#fff;}
  .hdr.solid{position:sticky;top:0;background:var(--ink);color:var(--cream);}
  .wrap{display:flex;align-items:center;justify-content:space-between;height:74px;gap:1rem;}
  .brand{display:flex;align-items:center;gap:.7rem;text-decoration:none;color:inherit;}
  .brand .mark{width:auto;height:40px;}
  .over .brand .mark{filter:drop-shadow(0 2px 8px rgba(0,0,0,.45));}
  .brand .wm{display:flex;flex-direction:column;line-height:1;}
  .brand .wm .t{font-family:var(--disp);font-size:1.6rem;letter-spacing:.01em;}
  .over .brand .wm .t{text-shadow:0 2px 10px rgba(0,0,0,.45);}
  .brand .wm .s{font-size:.62rem;letter-spacing:.22em;font-weight:700;margin-top:3px;text-transform:uppercase;opacity:.9;}
  .nav{display:flex;align-items:center;gap:clamp(10px,2vw,22px);}
  .nav .links{display:flex;gap:inherit;}
  .nav .links a{color:inherit;text-decoration:none;font-size:.78rem;font-weight:700;letter-spacing:.08em;text-transform:uppercase;opacity:.9;padding:4px 2px;border-bottom:2px solid transparent;transition:opacity .2s,border-color .2s;}
  .over .nav .links a{text-shadow:0 1px 6px rgba(0,0,0,.45);}
  .nav .links a:hover,.nav .links a[aria-current]{opacity:1;border-color:var(--yellow);}
  .lang{display:inline-flex;border:2px solid currentColor;border-radius:999px;overflow:hidden;opacity:.9;}
  .lang button{appearance:none;border:0;background:transparent;cursor:pointer;font:700 .74rem var(--sans);color:inherit;padding:6px 11px;min-width:42px;}
  .lang button[aria-pressed="true"]{background:var(--orange);color:#fff;}
  @media (max-width:820px){ .nav .links{display:none;} }
</style>

<script>
  const btn = document.getElementById('more-btn');
  const sheet = document.getElementById('more-sheet');
  if (btn && sheet) {
    btn.addEventListener('click', (e) => {
      e.stopPropagation();
      const open = sheet.classList.toggle('open');
      btn.setAttribute('aria-expanded', String(open));
    });
    document.addEventListener('click', (e) => {
      if (!sheet.contains(e.target as Node) && e.target !== btn) {
        sheet.classList.remove('open');
        if (!['trajets', 'carnet', 'galerie'].includes(document.body.dataset.active || '')) btn.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>
