---
// Header AMHE. variant="over" (transparent sur le hero) | "solid" (fond encre).
interface Props { variant?: 'over' | 'solid'; active?: string; }
const { variant = 'solid', active = '' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') + '/';
const icon = variant === 'over' ? 'amhe-icon-white.png' : 'amhe-icon-white.png';
const links = [
  { href: base, label: 'Accueil', key: 'accueil' },
  { href: base + 'parcours', label: 'Parcours', key: 'parcours' },
  { href: base + 'pays', label: 'Pays', key: 'pays' },
  { href: base + 'hotels', label: 'Hôtels', key: 'hotels' },
  { href: base + 'trajets', label: 'Trajets', key: 'trajets' },
  { href: base + 'carnet', label: 'Carnet', key: 'carnet' },
  { href: base + 'galerie', label: 'Galerie', key: 'galerie' },
];
---
<header class:list={['hdr', variant]}>
  <div class="wrap">
    <a class="brand" href={base}>
      <img class="mark" src={`${base}brand/${icon}`} alt="Logo AMHE" width="40" height="29" />
      <span class="wm"><span class="t">AMHE</span><span class="s">Atlas d'Asie</span></span>
    </a>
    <nav class="nav" aria-label="Principale">
      <span class="links">
        {links.map((l) => (
          <a href={l.href} aria-current={active === l.key ? 'page' : undefined}>{l.label}</a>
        ))}
      </span>
      <span class="lang" role="group" aria-label="Langue">
        <button type="button" aria-pressed="true">FR</button>
        <button type="button" aria-pressed="false">EN</button>
      </span>
      <button class="burger" aria-label="Menu">
        <svg width="20" height="20" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" fill="none"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
    </nav>
  </div>
</header>

<style>
  .hdr{z-index:40;}
  .hdr.over{position:absolute;top:0;left:0;right:0;color:#fff;}
  .hdr.solid{position:sticky;top:0;background:var(--ink);color:var(--cream);}
  .wrap{display:flex;align-items:center;justify-content:space-between;height:74px;gap:1rem;}
  .brand{display:flex;align-items:center;gap:.7rem;text-decoration:none;color:inherit;}
  .brand .mark{width:auto;height:40px;}
  .over .brand .mark{filter:drop-shadow(0 2px 8px rgba(0,0,0,.45));}
  .brand .wm{display:flex;flex-direction:column;line-height:1;}
  .brand .wm .t{font-family:var(--disp);font-size:1.6rem;letter-spacing:.01em;}
  .over .brand .wm .t{text-shadow:0 2px 10px rgba(0,0,0,.45);}
  .brand .wm .s{font-size:.62rem;letter-spacing:.22em;font-weight:700;margin-top:3px;text-transform:uppercase;opacity:.9;}
  .nav{display:flex;align-items:center;gap:clamp(10px,2vw,22px);}
  .nav .links{display:flex;gap:inherit;}
  .nav .links a{color:inherit;text-decoration:none;font-size:.78rem;font-weight:700;letter-spacing:.1em;text-transform:uppercase;opacity:.9;padding:4px 2px;border-bottom:2px solid transparent;transition:opacity .2s,border-color .2s;}
  .over .nav .links a{text-shadow:0 1px 6px rgba(0,0,0,.45);}
  .nav .links a:hover,.nav .links a[aria-current]{opacity:1;border-color:var(--yellow);}
  .lang{display:inline-flex;border:2px solid currentColor;border-radius:999px;overflow:hidden;opacity:.9;}
  .lang button{appearance:none;border:0;background:transparent;cursor:pointer;font:700 .74rem var(--sans);color:inherit;padding:6px 11px;min-width:42px;}
  .lang button[aria-pressed="true"]{background:var(--orange);color:#fff;}
  .burger{display:none;}
  @media (max-width:820px){
    .nav .links{display:none;}
    .burger{display:inline-grid;place-items:center;width:42px;height:42px;border:2px solid currentColor;border-radius:10px;background:transparent;color:inherit;cursor:pointer;}
  }
</style>
